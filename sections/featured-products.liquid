<section class="section" id="shop">
  <div class="wrap">
    <div class="section-head reveal" style="margin-bottom:44px;">
      <h2 style="font-family:var(--font-display); font-weight:600; font-size:clamp(34px,5vw,56px); line-height:1.02; letter-spacing:-.01em;">{{ section.settings.heading | default: 'Best Sellers' }}</h2>
    </div>
    <div class="bs-grid">
      {%- assign coll = collections[section.settings.collection] -%}
      {%- if coll != blank and coll.products.size > 0 -%}
        {%- for product in coll.products limit: section.settings.limit -%}
          {% render 'bestseller-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for product in collections.all.products limit: section.settings.limit -%}
          {% render 'bestseller-card', product: product %}
        {%- else -%}
          <p class="orivo-ph" style="grid-column:1/-1;">Add products to your store, then choose a collection here to populate this grid.</p>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Best sellers",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Best sellers" }]
}
{% endschema %}

<section class="section"><div class="wrap">
  <div class="section-head reveal" style="margin-bottom:34px;"><h1 style="font-family:var(--font-display);font-weight:600;font-size:clamp(34px,5vw,54px);">Collections</h1></div>
  <div class="bs-grid">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="bs-card reveal">
        <div class="bs-media">{% if collection.featured_image %}<img src="{{ collection.featured_image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" loading="lazy" width="800" height="800" style="width:100%;height:100%;object-fit:cover;">{% else %}<div class="orivo-ph"><span>{{ collection.title }}</span></div>{% endif %}</div>
        <div class="bs-meta">{{ collection.title }}</div>
      </a>
    {%- endfor -%}
  </div>
</div></section>
{% schema %}{ "name": "List collections" }{% endschema %}

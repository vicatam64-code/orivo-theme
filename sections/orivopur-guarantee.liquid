{{ 'orivopur-styles.css' | asset_url | stylesheet_tag }}
<section class='orivopur-section orivopur-guarantee' id='shopify-section-{{ section.id }}-inner'>
  <div class='orivopur-container'>
    <div style='max-width:680px;margin:0 auto;text-align:center;'>
      <p class='orivopur-eyebrow' style='color:#9ed1b4;'>{{ section.settings.eyebrow }}</p>
      <h2 class='orivopur-h2'>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body }}</p>
      {%- if section.settings.cta_label != blank -%}<div style='max-width:260px;margin:0 auto;'><a class='orivopur-btn orivopur-btn--amber' href='{{ section.settings.cta_link | default: "#" }}'>{{ section.settings.cta_label }}</a></div>{%- endif -%}
      <div class='orivopur-guarantee-badges'>
        <div><span class='em'>&#128737;</span>{{ section.settings.badge1 }}</div>
        <div><span class='em'>&#128666;</span>{{ section.settings.badge2 }}</div>
        <div><span class='em'>&#8617;</span>{{ section.settings.badge3 }}</div>
      </div>
    </div>
  </div>
</section>
<style>
  #shopify-section-{{ section.id }}{ background: var(--orivopur-ink); }
  #shopify-section-{{ section.id }} h2{ color:#ffffff; }
</style>
{% schema %}
{
  "name": "Orivo — Guarantee",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop with confidence" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "30-Day Money-Back Guarantee" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "If you are not completely happy with your Orivo pen, return it within 30 days for a full refund. No fuss." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Claim the offer" },
    { "type": "url", "id": "cta_link", "label": "Button link", "default": "/" },
    { "type": "text", "id": "badge1", "label": "Badge 1", "default": "100% Satisfaction" },
    { "type": "text", "id": "badge2", "label": "Badge 2", "default": "Fast Shipping" },
    { "type": "text", "id": "badge3", "label": "Badge 3", "default": "Easy Returns" }
  ],
  "presets": [{ "name": "Orivo — Guarantee" }]
}
{% endschema %}

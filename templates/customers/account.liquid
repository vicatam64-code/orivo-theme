<section class="section"><div class="wrap" style="max-width:720px;">
  <h1 style="font-family:var(--font-display);font-weight:600;font-size:34px;">Hi, {{ customer.first_name | default: 'there' }}</h1>
  <p style="margin:8px 0 24px;"><a href="{{ routes.account_logout_url }}" class="link-underline">Log out</a></p>
  <h3>Order history</h3>
  {%- if customer.orders.size > 0 -%}
    <ul>{%- for order in customer.orders -%}<li style="padding:8px 0;border-bottom:1px solid var(--line-soft);"><a href="{{ order.customer_url }}">{{ order.name }}</a> — {{ order.created_at | date: '%b %-d, %Y' }} — {{ order.total_price | money }} ({{ order.financial_status }})</li>{%- endfor -%}</ul>
  {%- else -%}<p class="lede">No orders yet.</p>{%- endif -%}
  <p style="margin-top:20px;"><a href="{{ routes.account_addresses_url }}" class="link-underline">Manage addresses</a></p>
</div></section>

<section class="trust-strip">
  <div class="wrap">
    <div class="row">
      {%- for block in section.blocks -%}
        <div class="ti" {{ block.shopify_attributes }}>{% render 'icon', name: block.settings.icon %}{{ block.settings.text }}</div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Trust strip",
  "blocks": [
    { "type": "item", "name": "Item", "settings": [
      { "type": "select", "id": "icon", "label": "Icon", "default": "shield",
        "options": [
          {"value":"shield","label":"Shield"},{"value":"truck","label":"Truck"},
          {"value":"clock","label":"Clock"},{"value":"chat","label":"Chat"} ] },
      { "type": "text", "id": "text", "label": "Text", "default": "60-night home trial" }
    ]}
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Trust strip", "blocks": [
    {"type":"item","settings":{"icon":"shield","text":"60-night home trial"}},
    {"type":"item","settings":{"icon":"truck","text":"Door-to-door delivery"}},
    {"type":"item","settings":{"icon":"clock","text":"2-year warranty"}},
    {"type":"item","settings":{"icon":"chat","text":"Locally supported"}}
  ]}]
}
{% endschema %}

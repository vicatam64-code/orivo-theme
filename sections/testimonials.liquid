<section class="section">
  <div class="wrap">
    <div class="section-head center reveal" style="margin-bottom:56px;">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="testi-grid">
      {%- for block in section.blocks -%}
        <div class="testi-card reveal" {{ block.shopify_attributes }}>
          <span class="stars">★★★★★</span>
          <p class="quote">"{{ block.settings.quote }}"</p>
          <div class="who"><span class="av">{{ block.settings.initials }}</span><div><b>{{ block.settings.name }}</b><small>{{ block.settings.location }}</small></div></div>
          {%- if block.settings.verified -%}<span class="vbadge">✓ Verified buyer</span>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved across SA" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From Joburg to the coast" }
  ],
  "blocks": [
    { "type": "review", "name": "Review", "settings": [
      { "type": "textarea", "id": "quote", "label": "Quote", "default": "Three weeks in and my skin honestly looks calmer and brighter." },
      { "type": "text", "id": "initials", "label": "Initials", "default": "LM" },
      { "type": "text", "id": "name", "label": "Name", "default": "Lerato M." },
      { "type": "text", "id": "location", "label": "Location", "default": "Sandton, GP" },
      { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true }
    ]}
  ],
  "max_blocks": 9,
  "presets": [{ "name": "Testimonials", "blocks": [
    {"type":"review","settings":{"quote":"Three weeks in and my skin honestly looks calmer and brighter. It's become my favourite part of winding down at night.","initials":"LM","name":"Lerato M.","location":"Sandton, GP"}},
    {"type":"review","settings":{"quote":"Delivery took 9 days to Durban and the device feels premium. My fine lines around the eyes look softer.","initials":"TN","name":"Thandeka N.","location":"Durban, KZN"}},
    {"type":"review","settings":{"quote":"Sceptical at first, but the routine is so relaxing I actually stick to it. Worth every Rand for the trial alone.","initials":"JR","name":"Johan v. Rensburg","location":"Stellenbosch, WC"}}
  ]}]
}
{% endschema %}

{%- liquid
  assign steps = blank
  if product != blank and product.metafields.custom.how_steps != blank
    assign steps = product.metafields.custom.how_steps.value
  endif
-%}
<section class="section how-it-works-section">
  <div class="wrap">
    <div class="sec-head reveal"><p class="eyebrow">{{ section.settings.eyebrow }}</p><h2>{{ section.settings.heading }}</h2></div>
    <div class="lux-how">
      {%- if steps != blank -%}
        {%- assign slines = steps | newline_to_br | split: '<br />' -%}
        {%- for line in slines -%}{%- assign sp = line | strip | split: '|' -%}{%- if sp.size > 1 -%}
          <div class="step reveal"><div class="n">{{ sp[0] | strip }}</div><h4>{{ sp[1] | strip }}</h4><p>{{ sp[2] | strip }}</p></div>
        {%- endif -%}{%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <div class="step reveal" {{ block.shopify_attributes }}><div class="n">{{ block.settings.number }}</div><h4>{{ block.settings.title }}</h4><p>{{ block.settings.text }}</p></div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "How it works",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The ritual" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How it works" }
  ],
  "blocks": [ { "type": "step", "name": "Step", "settings": [
    { "type": "text", "id": "number", "label": "Number", "default": "01" },
    { "type": "text", "id": "title", "label": "Title", "default": "Cleanse" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Start with clean, dry skin — no serums needed underneath." }
  ]}],
  "max_blocks": 6,
  "presets": [{ "name": "How it works", "blocks": [
    {"type":"step","settings":{"number":"01","title":"Cleanse","text":"Start with clean, dry skin — no serums needed underneath."}},
    {"type":"step","settings":{"number":"02","title":"Wear & relax","text":"Slip on the device, pick your mode and unwind for 10 minutes."}},
    {"type":"step","settings":{"number":"03","title":"Glow on","text":"Follow with your usual moisturiser. Repeat most evenings."}}
  ]}]
}
{% endschema %}

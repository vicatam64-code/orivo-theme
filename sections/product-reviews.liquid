{%- liquid
  assign rating = product.metafields.custom.rating | default: 4.7
  assign count = product.metafields.custom.review_count | default: 0
  assign dist_raw = product.metafields.custom.review_dist.value | default: product.metafields.custom.review_dist
  assign reviews_raw = product.metafields.custom.reviews.value | default: product.metafields.custom.reviews
-%}
{%- if reviews_raw != blank -%}
<section class="section lux-reviews" id="reviews">
  <div class="wrap">
    <div class="section-head reveal" style="margin-bottom:6px;">
      <h2 style="font-family:var(--font-display);font-weight:600;font-size:clamp(34px,5vw,56px);line-height:1.02;">{{ count }} {{ section.settings.heading | default: 'reviews & counting' }}</h2>
    </div>
    <div class="summary reveal">
      <div class="avg">
        <div class="num">{{ rating }}</div>
        <div class="stars">★★★★★</div>
        <small>{{ count }} verified reviews</small>
      </div>
      <div class="bars">
        {%- assign dparts = dist_raw | split: ',' -%}
        {%- assign total = 0 -%}
        {%- for d in dparts -%}{%- assign total = total | plus: d -%}{%- endfor -%}
        {%- for d in dparts -%}
          {%- assign starnum = 5 | minus: forloop.index0 -%}
          {%- assign pct = 0 -%}
          {%- if total > 0 -%}{%- assign pct = d | times: 100 | divided_by: total -%}{%- endif -%}
          <div class="bar"><span>{{ starnum }}★</span><span class="track"><span class="fill" style="width:{{ pct }}%"></span></span><span>{{ pct }}%</span></div>
        {%- endfor -%}
      </div>
    </div>
    <div class="rgrid">
      {%- assign rlines = reviews_raw | newline_to_br | split: '<br />' -%}
      {%- for line in rlines -%}
        {%- assign rp = line | strip | split: '|' -%}
        {%- if rp.size > 3 -%}
          {%- assign rnum = rp[0] | strip | times: 1 -%}
          {%- assign nm = rp[3] | strip -%}
          {%- assign words = nm | split: ' ' -%}
          {%- assign init1 = words[0] | slice: 0, 1 -%}
          {%- assign init2 = '' -%}
          {%- if words.size > 1 -%}{%- assign lastw = words | last -%}{%- assign init2 = lastw | slice: 0, 1 -%}{%- endif -%}
          {%- assign inits = init1 | append: init2 | upcase -%}
          {%- capture stars -%}{%- for i in (1..5) -%}{%- if i <= rnum -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}{%- endcapture -%}
          <div class="lux-rev reveal">
            <div class="top"><span class="stars">{{ stars }}</span><span class="date">{{ rp[5] | strip }}</span></div>
            <h4>{{ rp[1] | strip }}</h4>
            <p>"{{ rp[2] | strip }}"</p>
            <div class="who"><span class="av">{{ inits }}</span><div><b>{{ nm }}</b><small>{{ rp[4] | strip }}</small></div><span class="vbadge" style="margin-left:auto;">✓ Verified</span></div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
{% schema %}
{
  "name": "Product reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading suffix (after the count)", "default": "reviews & counting" },
    { "type": "paragraph", "content": "Reviews, the rating and the distribution come from each product's metafields (custom.reviews, custom.review_dist, custom.rating, custom.review_count), so every product shows its own." }
  ],
  "presets": [{ "name": "Product reviews" }]
}
{% endschema %}

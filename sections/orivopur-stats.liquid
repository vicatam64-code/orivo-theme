{{ 'orivopur-styles.css' | asset_url | stylesheet_tag }}
<section class='orivopur-section orivopur-stats' id='shopify-section-{{ section.id }}-inner'>
  <div class='orivopur-container'>
    <div style='text-align:center;max-width:680px;margin:0 auto;'>
      <h2 class='orivopur-h2'>{{ section.settings.heading }}</h2>
      <p class='orivopur-lead'>{{ section.settings.subheading }}</p>
    </div>
    <div class='orivopur-stats-grid'>
      {%- for block in section.blocks -%}
      <div class='orivopur-stat' {{ block.shopify_attributes }}>
        <b>{{ block.settings.number }}</b>
        <span>{{ block.settings.label }}</span>
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
  #shopify-section-{{ section.id }}{ background: var(--orivopur-surface-2); }
  #shopify-section-{{ section.id }} h2{ color: var(--orivopur-ink); }
</style>
{% schema %}
{
  "name": "Orivo — Stats",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Tell Us" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Edit these with your own verified survey results." }
  ],
  "blocks": [
    { "type": "stat", "name": "Stat", "settings": [
      { "type": "text", "id": "number", "label": "Number", "default": "9 in 10" },
      { "type": "textarea", "id": "label", "label": "Label", "default": "Said they would buy it again" }
    ]}
  ],
  "max_blocks": 8,
  "presets": [{ "name": "Orivo — Stats", "blocks": [
    { "type": "stat", "settings": { "number": "9 in 10", "label": "Loved the fresh, cooling sensation" } },
    { "type": "stat", "settings": { "number": "94%", "label": "Said it was easy to use day to day" } },
    { "type": "stat", "settings": { "number": "4.8★", "label": "Average customer rating" } },
    { "type": "stat", "settings": { "number": "30-Day", "label": "Money-back guarantee" } }
  ] }]
}
{% endschema %}

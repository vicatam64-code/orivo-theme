  <span class="pay-badge" title="Mastercard"><svg viewBox="0 0 48 30" role="img" aria-label="Mastercard"><rect width="48" height="30" rx="4" fill="#fff" stroke="#E7E0D5"/><circle cx="20.5" cy="15" r="7" fill="#EB001B"/><circle cx="27.5" cy="15" r="7" fill="#F79E1B"/><path d="M24 9.8a7 7 0 0 0 0 10.4 7 7 0 0 0 0-10.4z" fill="#FF5F00"/></svg></span>

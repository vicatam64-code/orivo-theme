<section class="section"><div class="wrap" style="max-width:420px;">
  <h1 style="font-family:var(--font-display);font-weight:600;font-size:30px;margin-bottom:18px;">Activate account</h1>
  {%- form 'activate_customer_password' -%}
    <div class="field"><label>Password</label><input type="password" name="customer[password]" required></div>
    <div class="field"><label>Confirm</label><input type="password" name="customer[password_confirmation]" required></div>
    <button type="submit" class="btn btn-accent btn-lg btn-block" style="margin-top:12px;">Activate</button>
  {%- endform -%}
</div></section>

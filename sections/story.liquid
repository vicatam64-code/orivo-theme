<section class="section story bg-deep" id="story">
  <div class="wrap">
    <div class="grid">
      <div class="reveal">{% render 'image-slot', image: section.settings.image, placeholder: 'Brand / founder image', radius: 24 %}</div>
      <div class="body reveal">
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <div class="rte">{{ section.settings.body }}</div>
        {%- if section.settings.signature != blank -%}<p class="sig">{{ section.settings.signature }}</p>{%- endif -%}
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Brand story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Born from a belief that wellness should feel calm." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Orivo began in Johannesburg with a simple idea: the most effective rituals are the ones you actually look forward to.</p><p>Every device is engineered around proven wavelengths, tested for safety, and designed to slip effortlessly into your evenings.</p>" },
    { "type": "text", "id": "signature", "label": "Signature", "default": "— The Orivo team" }
  ],
  "presets": [{ "name": "Brand story" }]
}
{% endschema %}

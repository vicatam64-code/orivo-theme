<section class="section"><div class="wrap" style="max-width:440px;">
  <h1 style="font-family:var(--font-display);font-weight:600;font-size:34px;margin-bottom:20px;">Create account</h1>
  {%- form 'create_customer' -%}
    <div class="field"><label>First name</label><input type="text" name="customer[first_name]"></div>
    <div class="field"><label>Last name</label><input type="text" name="customer[last_name]"></div>
    <div class="field"><label>Email</label><input type="email" name="customer[email]" required></div>
    <div class="field"><label>Password</label><input type="password" name="customer[password]" required></div>
    <button type="submit" class="btn btn-accent btn-lg btn-block" style="margin-top:12px;">Create</button>
  {%- endform -%}
</div></section>

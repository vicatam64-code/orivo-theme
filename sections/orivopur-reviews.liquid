{{ 'orivopur-styles.css' | asset_url | stylesheet_tag }}
<section class='orivopur-section orivopur-reviews' id='shopify-section-{{ section.id }}-inner'>
  <div class='orivopur-container'>
    <div class='orivopur-reviews-head' style='max-width:680px;margin:0 auto;'>
      <p class='orivopur-eyebrow'>{{ section.settings.eyebrow }}</p>
      <h2 class='orivopur-h2'>{{ section.settings.heading }}</h2>
      <p class='orivopur-lead'>{{ section.settings.subheading }}</p>
    </div>
    <div class='orivopur-reviews-grid'>
      {%- for block in section.blocks -%}
      <div class='orivopur-review' {{ block.shopify_attributes }}>
        <div class='orivopur-stars'>&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p>{{ block.settings.quote }}</p>
        <div class='orivopur-review-top' style='margin-top:14px;margin-bottom:0;'>
          {%- if block.settings.avatar != blank -%}<img class='orivopur-review-av' src='{{ block.settings.avatar | image_url: width: 120 }}' alt='{{ block.settings.name | escape }}' width='48' height='48'>{%- else -%}<div class='orivopur-review-av'></div>{%- endif -%}
          <div>
            <div class='orivopur-review-name'>{{ block.settings.name }}</div>
            <div class='orivopur-review-tag'>{{ block.settings.tag }}</div>
          </div>
        </div>
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
  #shopify-section-{{ section.id }}{ background: var(--orivopur-bg); }
  #shopify-section-{{ section.id }} h2{ color: var(--orivopur-ink); }
</style>
{% schema %}
{
  "name": "Orivo — Reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved by customers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real People. Real Routines." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Replace these with your own verified customer reviews." }
  ],
  "blocks": [
    { "type": "review", "name": "Review", "settings": [
      { "type": "image_picker", "id": "avatar", "label": "Avatar" },
      { "type": "text", "id": "name", "label": "Name", "default": "Customer" },
      { "type": "text", "id": "tag", "label": "Tag", "default": "Verified Buyer" },
      { "type": "textarea", "id": "quote", "label": "Quote", "default": "I keep it in my bag and reach for it whenever I want a fresh, calming breath." }
    ]}
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Orivo — Reviews", "blocks": [
    { "type": "review", "settings": { "name": "Thandi M.", "tag": "Verified Buyer", "quote": "The mint and mullein combo is so refreshing. It has become part of my morning routine." } },
    { "type": "review", "settings": { "name": "James P.", "tag": "Verified Buyer", "quote": "Discreet and easy to carry. I like having a quick calming ritual at my desk." } },
    { "type": "review", "settings": { "name": "Lerato K.", "tag": "Verified Buyer", "quote": "No mess, no taste, just a clean cooling breath. The bundle was great value." } },
    { "type": "review", "settings": { "name": "Daniel V.", "tag": "Verified Buyer", "quote": "Arrived quickly and feels well made. Happy with the purchase." } }
  ] }]
}
{% endschema %}

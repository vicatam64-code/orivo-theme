{{ 'orivopur-styles.css' | asset_url | stylesheet_tag }}
<section class='orivopur-section orivopur-cta-band' id='shopify-section-{{ section.id }}-inner'>
  <div class='orivopur-container' style='text-align:center;max-width:720px;'>
    <h2 class='orivopur-h2'>{{ section.settings.heading }}</h2>
    <p class='orivopur-lead'>{{ section.settings.subheading }}</p>
    <div style='max-width:300px;margin:22px auto 0;'><a class='orivopur-btn orivopur-btn--amber' href='{{ section.settings.cta_link }}'>{{ section.settings.cta_label }}</a></div>
  </div>
</section>
<style>
  #shopify-section-{{ section.id }}{ background: var(--orivopur-surface-2); }
  #shopify-section-{{ section.id }} h2{ color: var(--orivopur-ink); }
</style>
{% schema %}
{
  "name": "Orivo — CTA Band",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready for a fresher breath?" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Try the Orivo Herbal Airway Pen risk-free with our 30-day money-back guarantee." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop now" },
    { "type": "text", "id": "cta_link", "label": "Button link", "default": "/products/orivo-herbal-airway-pen-mullein-mint" }
  ],
  "presets": [{ "name": "Orivo — CTA Band" }]
}
{% endschema %}
